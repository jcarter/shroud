## Ansible-managed: roles/auditd/templates/audit.rules.j2
## Delete all existing rules first
-D

## Increase the kernel audit buffer to survive high-load events
-b {{ audit_backlog_limit }}

## Failure mode: 1 = printk (non-fatal), 2 = panic (immutable rules)
-f 1

## ---- Identity & authentication ----
-w /etc/group           -p wa -k identity
-w /etc/passwd          -p wa -k identity
-w /etc/gshadow         -p wa -k identity
-w /etc/shadow          -p wa -k identity
-w /etc/security/opasswd -p wa -k identity
-w /etc/pam.d/          -p wa -k pam

## ---- Privilege escalation ----
-w /bin/su              -p x  -k priv_esc
-w /usr/bin/sudo        -p x  -k priv_esc
-w /etc/sudoers         -p wa -k priv_esc
-w /etc/sudoers.d/      -p wa -k priv_esc

## ---- Kernel module manipulation ----
-w /sbin/insmod         -p x  -k module_insertion
-w /sbin/rmmod          -p x  -k module_insertion
-w /sbin/modprobe       -p x  -k module_insertion
-a always,exit -F arch=b64 -S init_module -S delete_module -k module_insertion

## ---- Network configuration changes ----
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k network_modification
-w /etc/hosts           -p wa -k network_modification
-w /etc/network/        -p wa -k network_modification

## ---- System time changes ----
-a always,exit -F arch=b64 -S adjtimex -S settimeofday              -k time_change
-a always,exit -F arch=b32 -S adjtimex -S settimeofday -k time_change
-a always,exit -F arch=b64 -S clock_settime                          -k time_change
-w /etc/localtime       -p wa -k time_change

## ---- File deletions by non-system users ----
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k file_deletion

## ---- Unauthorized file access attempts ----
-a always,exit -F arch=b64 -S creat -S open -S openat -S open_by_handle_at -S truncate -S ftruncate -F exit=-EACCES -F auid>=1000 -F auid!=4294967295 -k access
-a always,exit -F arch=b64 -S creat -S open -S openat -S open_by_handle_at -S truncate -S ftruncate -F exit=-EPERM -F auid>=1000 -F auid!=4294967295 -k access

## ---- Login tracking ----
-w /var/log/lastlog     -p wa -k logins
-w /var/run/faillock    -p wa -k logins

## ---- SSH configuration changes ----
-w /etc/ssh/sshd_config -p wa -k sshd_config

## ---- Make rules immutable after load (uncomment when rules are stable) ----
## Enabling this requires a reboot to change rules.
## -e 2
